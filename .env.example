NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/veolms
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change_me_to_64_char_hex_string_minimum_32_chars_long
JWT_REFRESH_SECRET=change_me_to_another_64_char_hex_string_minimum_32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
# Playlist JWT: short-lived auth for /api/videos/stream (recommended 15–20 min)
VIDEO_TOKEN_EXPIRY_SECONDS=1200
# Signed .ts segment URLs: long enough for pause/seek on long videos (2–4 hours)
VIDEO_SEGMENT_URL_EXPIRY_SECONDS=7200
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=veo-lms
# Public r2.dev or custom domain for images/thumbnails only — keep videos/ private in R2.
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev
R2_ENDPOINT=
RAZORPAY_KEY_ID=rzp_test_SySwZtWbZUFOHI
RAZORPAY_KEY_SECRET=gguHNN59ncsoGxekouZvWdG6
FRONTEND_URL=http://localhost:5173
ADMIN_EMAIL=admin@veolms.com
ADMIN_PASSWORD=Admin@123456
# Production (Railway Hobby): outbound SMTP is blocked — use Resend HTTPS API instead.
# Sign up at https://resend.com → API Keys → add to Railway variables.
RESEND_API_KEY=
EMAIL_FROM=VeoLMS <onboarding@resend.dev>

# Local dev: Gmail SMTP works on your machine (not on Railway Hobby).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=VeoLMS <noreply@veolms.com>

# Frontend (Vite) — copy to apps/client/.env or root .env
VITE_API_URL=http://localhost:5000/api
VITE_WS_URL=ws://localhost:5000
VITE_APP_NAME=VeoLMS
VITE_RAZORPAY_KEY_ID=rzp_test_SySwZtWbZUFOHI
# Public R2 CDN base for images, thumbnails, avatars, resources (no trailing slash)
VITE_ASSET_BASE_URL=https://pub-your-bucket-id.r2.dev
# Legacy alias — VITE_ASSET_BASE_URL is preferred
VITE_VIDEO_ASSET_BASE_URL=https://pub-your-bucket-id.r2.dev
