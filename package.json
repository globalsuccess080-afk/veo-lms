{
  "name": "veolms",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "npm run dev -w @veolms/server",
    "dev:client": "npm run dev -w @veolms/client",
    "build": "npm run build -w @veolms/shared && npm run build -w @veolms/server && npm run build -w @veolms/client",
    "start": "npm run start -w @veolms/server",
    "seed": "npm run seed -w @veolms/server",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspaces --if-present"
  },
  "devDependencies": {},
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7"
  }
}
